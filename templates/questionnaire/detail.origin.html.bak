<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ questionnaire.title }} - 详情</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .delete-btn {
            position: absolute;
            top: 10px;
            right: 10px;
        }
        .update-notification {
            animation: slideInDown 0.5s ease-out;
        }
        @keyframes slideInDown {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
        .update-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
        }
        .copy-success {
        color: #28a745;
        font-size: 0.875rem;
        margin-top: 5px;
        display: none; /* 默认隐藏 */
        }
        .copy-link-container {
            position: relative;
        }
        .link-input-group {
            margin-bottom: 5px;
        }
        .link-label {
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 5px;
            color: #495057;
        }

    </style>
</head>
<body>
    <!-- 使用 navbar.html 而不是 base.html -->
    {% include 'navbar.html' %}

    <div id="update-notification" class="container mt-3" style="display: none;">
        <div class="alert alert-warning update-notification">
            <div class="d-flex align-items-center">
                <i class="fas fa-exclamation-triangle me-3"></i>
                <div class="flex-grow-1">
                    <h6 class="mb-1">问卷已更新</h6>
                    <p class="mb-2" id="update-message"></p>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted" id="version-info"></small>
                        <div>
                            <button type="button" class="btn btn-sm btn-outline-secondary me-1" onclick="remindLater()">
                                稍后
                            </button>
                            <button type="button" class="btn btn-sm btn-primary" onclick="acknowledgeUpdate()" id="acknowledge-btn">
                                知道了
                            </button>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn-close" onclick="dismissNotification()" aria-label="关闭"></button>
            </div>
        </div>
    </div>

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">{{ questionnaire.title }}</h4>
                        {% if questionnaire.creator == request.user or request.user.is_admin %}
                        <div class="btn-group">
                            <!-- 删除问卷按钮 -->
                            <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal{{ questionnaire.id }}">
                                <i class="fas fa-trash"></i> 删除问卷
                            </button>
                        </div>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        {% if questionnaire.description %}
                        <p class="card-text">{{ questionnaire.description }}</p>
                        <hr>
                        {% endif %}

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <p><strong>状态:</strong>
                                    <span class="badge {% if questionnaire.status == 'published' %}bg-success{% elif questionnaire.status == 'draft' %}bg-warning{% else %}bg-secondary{% endif %}">
                                        {{ questionnaire.get_status_display }}
                                    </span>
                                </p>
                                <p><strong>访问权限:</strong> {{ questionnaire.get_access_type_display }}</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>创建者:</strong> {{ questionnaire.creator.username }}</p>
                                <p><strong>创建时间:</strong> {{ questionnaire.created_at|date:"Y-m-d H:i" }}</p>
                            </div>
                        </div>

                        <!-- 修改后的按钮组 -->
                        <div class="d-flex gap-2 mb-4">
                            {% if questionnaire.creator == request.user or is_admin %}
                            <a href="{% url 'edit_questionnaire' questionnaire.id %}" class="btn btn-primary">
                                <i class="fas fa-edit me-1"></i>编辑问卷
                            </a>
                            {% endif %}

                            <!-- 发布按钮 - 只对草稿状态的问卷显示 -->
                            <!-- 修复这里的条件：Django模板中不支持括号，要拆分成两个判断 -->
                            {% if questionnaire.status == 'draft' %}
                                {% if questionnaire.creator == request.user or is_admin %}
                                <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#publishModal">
                                    <i class="fas fa-paper-plane me-1"></i>发布问卷
                                </button>
                                {% endif %}
                            {% endif %}

                            <a href="{% url 'survey_form' questionnaire.id %}" class="btn btn-success">
                                <i class="fas fa-play-circle me-1"></i>填写问卷
                            </a>
                        </div>

                        <h5 class="mb-3">问卷问题</h5>
                        {% if questions %}
                        <div class="list-group">
                            {% for question in questions %}
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between align-items-center">
                                    <h6 class="mb-1">{{ forloop.counter }}. {{ question.text }}</h6>
                                    <div class="d-flex align-items-center">
                                        <small class="text-muted me-3">{{ question.get_question_type_display }}</small>
                                        {% if question.answer_items.count > 0 %}
                                            <!-- 回答数量提示 -->
                                            <span class="badge bg-warning me-2" title="此问题已有回答记录">
                                                {{ question.answer_items.count }} 个回答
                                            </span>
                                        {% endif %}
                                        <!-- 版本历史链接 -->
                                        <a href="{% url 'question_version_history' question.id %}"  
                                           class="btn btn-sm btn-outline-info" 
                                           title="查看版本历史">
                                            <i class="fas fa-history"></i>
                                        </a>
                                    </div>
                                </div>
                                {% if question.question_type in 'radio,checkbox' and question.options %}
                                <div class="mt-2">
                                    <small class="text-muted">选项:</small>
                                    <div class="mt-1">
                                        {% for option in question.options %}
                                        <div class="form-check">
                                            {% if question.question_type == 'radio' %}
                                            <input class="form-check-input" type="radio" disabled>
                                            {% else %}
                                            <input class="form-check-input" type="checkbox" disabled>
                                            {% endif %}
                                            <label class="form-check-label">{{ option }}</label>
                                        </div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% elif question.question_type == 'text' %}
                                <div class="mt-2">
                                    <textarea class="form-control" rows="2" placeholder="简答题回答区域" disabled></textarea>
                                    {% if question.max_length > 0 %}
                                    <small class="text-muted">字数限制: {{ question.max_length }}字</small>
                                    {% endif %}
                                </div>
                                {% endif %}
                                <div class="mt-2">
                                    <small class="text-muted">{% if question.required %}必填{% else %}选填{% endif %}</small>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        {% else %}
                        <div class="alert alert-warning">暂无问题</div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">统计信息</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>访问次数:</strong> {{ questionnaire.view_count }}</p>
                        <p><strong>提交次数:</strong> {{ questionnaire.submit_count }}</p>
                        <p><strong>问卷状态:</strong>
                            {% if questionnaire.status == 'published' %}
                            <span class="text-success">已发布</span>
                            {% elif questionnaire.status == 'draft' %}
                            <span class="text-warning">草稿</span>
                            {% else %}
                            <span class="text-secondary">已关闭</span>
                            {% endif %}
                        </p>
                        <p><strong>版本:</strong>
                            <span class="badge bg-info update-badge">v{{ questionnaire.version }}</span>
                            {% if questionnaire.status == 'modified' %}
                                <span class="badge bg-warning update-badge ms-1">已更新</span>
                            {% endif %}
                        </p>
                        <hr>
                        <div class="text-center">
                            <h6>问卷信息</h6>
                            {% if questionnaire.access_type == 'invite' %}
                                {% if questionnaire.creator == request.user or is_admin %}
                                    <div class="mb-2">
                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                onclick="toggleInviteCode()" id="inviteCodeBtn">
                                            点击显示邀请码
                                        </button>
                                    </div>
                                    <div id="inviteCodeContainer" style="display: none;">
                                        <div class="input-group input-group-sm mb-2">
                                            <input type="text" class="form-control text-center"
                                                   id="inviteCodeInput"
                                                   value="{{ questionnaire.invite_code }}" readonly>
                                            <button class="btn btn-outline-secondary" type="button"
                                                    onclick="copyInviteCode()">
                                                <i class="fas fa-copy"></i>
                                            </button>
                                        </div>
                                        <p class="small text-muted">仅限被邀请用户使用</p>
                                    </div>
                                {% else %}
                                    <p class="text-muted small">此问卷需要邀请码才能访问</p>
                                {% endif %}
                            {% endif %}
                            <!-- 原有的二维码显示部分保持不动 -->
                            {% if questionnaire.qr_code %}
                                <hr>
                                <div class="text-center">
                                    <h6>问卷二维码</h6>
                                    <img src="{{ questionnaire.qr_code.url }}" alt="二维码" class="img-fluid mb-2" style="max-width: 150px;">
                                    <p class="small text-muted">扫描二维码访问问卷</p>
                                     <div class="copy-link-container">
                                        <div class="link-label">问卷链接：</div>
                                        <div class="input-group input-group-sm link-input-group">
                                            {% if request.is_secure %}
                                                {% url 'survey_access' questionnaire.id as survey_url %}
                                            {% else %}
                                                {% url 'survey_access' questionnaire.id as survey_url %}
                                            {% endif %}
                                            <input type="text" class="form-control"
                                                   id="questionnaire-link"
                                                   value="{{ request.scheme }}://{{ request.get_host }}{{ survey_url }}"
                                                   readonly>
                                            <button class="btn btn-outline-primary" type="button"
                                                    onclick="copyQuestionnaireLink()"
                                                    title="复制链接">
                                                <i class="fas fa-copy"></i>
                                            </button>
                                        </div>
                                        <div class="copy-success" id="copy-success">
                                            <i class="fas fa-check-circle me-1"></i>链接已复制到剪贴板
                                        </div>
                                     </div>
                                </div>
                            {% endif %}
                        </div>
                        <script>
                            function toggleInviteCode() {
                                const container = document.getElementById('inviteCodeContainer');
                                const btn = document.getElementById('inviteCodeBtn');
                                if (container.style.display === 'none') {
                                    container.style.display = 'block';
                                    btn.textContent = '隐藏邀请码';
                                } else {
                                    container.style.display = 'none';
                                    btn.textContent = '点击显示邀请码';
                                }
                            }
                            function copyInviteCode() {
                                const input = document.getElementById('inviteCodeInput');
                                input.select();
                                document.execCommand('copy');
                                alert('邀请码已复制到剪贴板');
                            }
                            <!-- 复制问卷链接函数 -->
                            function copyQuestionnaireLink() {
                                const linkInput = document.getElementById('questionnaire-link');
                                const copySuccess = document.getElementById('copy-success');

                                // 选中链接文本
                                linkInput.select();
                                linkInput.setSelectionRange(0, 99999); // 对于移动设备

                                // 复制到剪贴板
                                try {
                                    document.execCommand('copy');

                                    // 显示成功消息
                                    copySuccess.style.display = 'block';

                                    // 3秒后隐藏成功消息
                                    setTimeout(() => {
                                        copySuccess.style.display = 'none';
                                    }, 3000);

                                    // 可选：显示全局成功消息
                                    showSuccessMessage('问卷链接已复制到剪贴板');
                                } catch (err) {
                                    console.error('复制失败:', err);
                                    alert('复制失败，请手动复制链接');
                                }
                            }
                            function copyQuestionnaireLinkModern() {
                                const linkInput = document.getElementById('questionnaire-link');
                                const copySuccess = document.getElementById('copy-success');

                                // 使用现代复制API 现代方法：navigator.clipboard.writeText() - 更安全可靠
                                if (navigator.clipboard && navigator.clipboard.writeText) {
                                    navigator.clipboard.writeText(linkInput.value)
                                        .then(() => {
                                            // 显示成功消息
                                            copySuccess.style.display = 'block';

                                            // 3秒后隐藏成功消息
                                            setTimeout(() => {
                                                copySuccess.style.display = 'none';
                                            }, 3000);

                                            showSuccessMessage('问卷链接已复制到剪贴板');
                                        })
                                        .catch(err => {
                                            console.error('复制失败:', err);
                                            // 降级到传统方法 传统方法：document.execCommand('copy') - 兼容旧浏览器
                                            linkInput.select();
                                            document.execCommand('copy');
                                            copySuccess.style.display = 'block';
                                            setTimeout(() => {
                                                copySuccess.style.display = 'none';
                                            }, 3000);
                                        });
                                } else {
                                    // 降级到传统方法
                                    linkInput.select();
                                    document.execCommand('copy');
                                    copySuccess.style.display = 'block';
                                    setTimeout(() => {
                                        copySuccess.style.display = 'none';
                                    }, 3000);
                                }
                            }

                            <!-- 更新按钮点击事件使用现代复制方法 -->
                            document.addEventListener('DOMContentLoaded', function() {
                                const copyBtn = document.querySelector('.btn-outline-primary[onclick="copyQuestionnaireLink()"]');
                                if (copyBtn) {
                                    copyBtn.setAttribute('onclick', 'copyQuestionnaireLinkModern()');
                                }
                            });
                        </script>
                        <hr>
                        <h6>最近回答</h6>
                        {% if responses %}
                        <div class="list-group list-group-flush">
                            {% for response in responses|slice:":5" %}
                            <div class="list-group-item px-0">
                                <small>
                                    {{ response.user.username }} -
                                    {{ response.submitted_at|date:"m-d H:i" }}
                                    {% if response.needs_update %}
                                    <span class="badge bg-warning update-badge ms-1">需更新</span>
                                    {% endif %}
                                </small>
                            </div>
                            {% endfor %}
                        </div>
                        {% else %}
                        <p class="text-muted small">暂无回答</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 发布问卷模态框 -->
    <div class="modal fade" id="publishModal" tabindex="-1" aria-labelledby="publishModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="publishForm" method="post" action="{% url 'ajax_publish_questionnaire' questionnaire.id %}">
                    {% csrf_token %}
                    <div class="modal-header bg-warning text-white">
                        <h5 class="modal-title" id="publishModalLabel">
                            <i class="fas fa-paper-plane me-2"></i>发布问卷
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="关闭"></button>
                    </div>
                    <div class="modal-body">
                        <!-- 验证提示 -->
                        <div class="alert alert-info mb-3">
                            <i class="fas fa-info-circle me-2"></i>
                            发布前系统会自动验证问卷内容是否完整
                        </div>

                        <!-- 访问权限设置 -->
                        <div class="mb-3">
                            <label for="accessType" class="form-label">访问权限</label>
                            <select class="form-select" id="accessType" name="access_type" required>
                                <option value="public" {% if questionnaire.access_type == 'public' %}selected{% endif %}>公开 - 任何人都可以填写</option>
                                <option value="private" {% if questionnaire.access_type == 'private' %}selected{% endif %}>私有 - 需要登录才能填写</option>
                                <option value="invite" {% if questionnaire.access_type == 'invite' %}selected{% endif %}>仅邀请 - 需要邀请码才能填写</option>
                            </select>
                            <div class="form-text">
                                选择问卷的访问方式，发布后可以修改
                            </div>
                        </div>

                        <!-- 邀请码设置（根据选择动态显示） -->
                        <div class="mb-3" id="inviteCodeSection" style="display: none;">
                            <label for="inviteCode" class="form-label">邀请码</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="inviteCode"
                                       name="invite_code"
                                       placeholder="留空则自动生成邀请码">
                                <button type="button" class="btn btn-outline-secondary" onclick="generateInviteCode()">
                                    <i class="fas fa-redo"></i> 生成
                                </button>
                            </div>
                            <div class="form-text">
                                仅被邀请的用户可以使用此码访问问卷
                            </div>
                        </div>

                        <!-- 验证结果区域 -->
                        <div id="validationResults" class="mt-3" style="display: none;">
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <span id="validationMessage">正在验证问卷内容...</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                        <button type="submit" class="btn btn-warning" id="publishButton">
                            <span id="publishButtonText">
                                <i class="fas fa-paper-plane me-1"></i>确认发布
                            </span>
                            <span id="publishLoading" style="display: none;">
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                发布中...
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- 删除问卷模态框 -->
    {% if questionnaire.creator == request.user or request.user.is_admin %}
    <div class="modal fade" id="deleteModal{{ questionnaire.id }}" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">确认删除问卷</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>您确定要删除问卷 <strong>"{{ questionnaire.title }}"</strong> 吗？</p>
                    <p class="text-danger">此操作不可恢复，问卷的所有问题和回答都将被删除！</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <form method="post" action="{% url 'delete_questionnaire' questionnaire.id %}?next={% url 'questionnaire_list' %}">
                        {% csrf_token %}
                        <button type="submit" class="btn btn-danger">确认删除</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- 仅添加：更新通知功能 -->
    <script>
    // 获取问卷ID
    const questionnaireId = '{{ questionnaire.id }}';

    // 检查更新
    function checkForUpdate() {
        fetch(`/questionnaires/${questionnaireId}/check-update/`)
            .then(response => response.json())
            .then(data => {
                if (data.needs_update) {
                    showUpdateNotification(data);
                }
            })
            .catch(error => {
                console.error('检查更新失败:', error);
            });
    }

    // 显示更新通知
    function showUpdateNotification(data) {
        const container = document.getElementById('update-notification');
        const message = document.getElementById('update-message');
        const versionInfo = document.getElementById('version-info');

        message.textContent = data.update_message;
        versionInfo.textContent = `版本 ${data.user_version} → ${data.current_version}`;
        container.style.display = 'block';

        // 10秒后自动隐藏
        setTimeout(() => {
            if (container.style.display !== 'none') {
                dismissNotification();
            }
        }, 10000);
    }

    // 关闭通知
    function dismissNotification() {
        document.getElementById('update-notification').style.display = 'none';
    }

    // 稍后提醒
    function remindLater() {
        dismissNotification();
        // 5分钟后重新检查
        setTimeout(checkForUpdate, 5 * 60 * 1000);
    }

    // 确认更新
    function acknowledgeUpdate() {
        const button = document.getElementById('acknowledge-btn');
        const originalText = button.textContent;
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        fetch(`/questionnaires/${questionnaireId}/acknowledge-update/`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.status === 'success') {
                dismissNotification();
                showSuccessMessage('更新已确认');
            } else {
                button.disabled = false;
                button.textContent = originalText;
                alert('确认失败: ' + data.message);
            }
        })
        .catch(error => {
            console.error('确认更新失败:', error);
            button.disabled = false;
            button.textContent = originalText;
            alert('确认失败，请重试');
        });
    }

    // 显示成功消息
    function showSuccessMessage(msg) {
        const existingAlert = document.querySelector('.success-alert');
        if (existingAlert) {
            existingAlert.remove();
        }
        const alert = document.createElement('div');
        alert.className = 'alert alert-success alert-dismissible fade show position-fixed';
        alert.style.cssText = 'top: 20px; right: 20px; z-index: 1050; max-width: 300px;';
        alert.innerHTML = `
            <i class="fas fa-check-circle me-2"></i>${msg}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alert);

        setTimeout(() => {
        if (alert.parentNode) {
            alert.classList.remove('show');
            setTimeout(() => {
                if (alert.parentNode) {
                    alert.remove();
                }
            }, 150);
        }
    }, 3000);
    }

    // 获取CSRF token
    function getCookie(name) {
        let cookieValue = null;
        if (document.cookie && document.cookie !== '') {
            const cookies = document.cookie.split(';');
            for (let i = 0; i < cookies.length; i++) {
                const cookie = cookies[i].trim();
                if (cookie.substring(0, name.length + 1) === (name + '=')) {
                    cookieValue = decodeURIComponent(cookie.substring(name.length + 1));
                    break;
                }
            }
        }
        return cookieValue;
    }

    // 页面加载后检查更新
    document.addEventListener('DOMContentLoaded', function() {
        // 延迟1秒检查，让页面先加载
        setTimeout(checkForUpdate, 1000);
    });
    </script>

    <!-- 保留原有的邀请码脚本 -->
    <script>
        function toggleInviteCode() {
            const container = document.getElementById('inviteCodeContainer');
            const btn = document.getElementById('inviteCodeBtn');
            if (container.style.display === 'none') {
                container.style.display = 'block';
                btn.textContent = '隐藏邀请码';
            } else {
                container.style.display = 'none';
                btn.textContent = '点击显示邀请码';
            }
        }
        function copyInviteCode() {
            const input = document.getElementById('inviteCodeInput');
            input.select();
            document.execCommand('copy');
            // 使用新的成功消息函数
            showSuccessMessage('邀请码已复制到剪贴板');
        }
    </script>
<script>
// 显示/隐藏邀请码输入框
document.getElementById('accessType').addEventListener('change', function() {
    const inviteCodeSection = document.getElementById('inviteCodeSection');
    if (this.value === 'invite') {
        inviteCodeSection.style.display = 'block';
    } else {
        inviteCodeSection.style.display = 'none';
    }
});

// 初始化时检查一次
document.addEventListener('DOMContentLoaded', function() {
    const accessTypeSelect = document.getElementById('accessType');
    if (accessTypeSelect && accessTypeSelect.value === 'invite') {
        document.getElementById('inviteCodeSection').style.display = 'block';
    }
});

// 生成邀请码
function generateInviteCode() {
    const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
    let result = '';
    for (let i = 0; i < 8; i++) {
        result += characters.charAt(Math.floor(Math.random() * characters.length));
    }
    document.getElementById('inviteCode').value = result;
}

// 表单提交处理
document.getElementById('publishForm').addEventListener('submit', function(e) {
    e.preventDefault();

    const publishButton = document.getElementById('publishButton');
    const publishButtonText = document.getElementById('publishButtonText');
    const publishLoading = document.getElementById('publishLoading');
    const validationResults = document.getElementById('validationResults');
    const validationMessage = document.getElementById('validationMessage');

    // 显示加载状态
    publishButton.disabled = true;
    publishButtonText.style.display = 'none';
    publishLoading.style.display = 'inline';

    // 显示验证提示
    validationResults.style.display = 'block';
    validationMessage.textContent = '正在验证问卷内容...';

    // 收集表单数据
    const formData = new FormData(this);

    // 发送AJAX请求
    fetch(this.action, {
        method: 'POST',
        headers: {
            'X-CSRFToken': getCookie('csrftoken'),
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 发布成功
            showSuccessMessage('问卷已成功发布！');

            // 更新页面内容
            updatePageAfterPublish(data);

            // 关闭模态框
            const modal = bootstrap.Modal.getInstance(document.getElementById('publishModal'));
            modal.hide();
        } else {
            // 显示错误信息
            validationMessage.textContent = data.message || '发布失败，请检查问卷内容';

            if (data.errors) {
                let errorList = '';
                if (Array.isArray(data.errors)) {
                    errorList = '<ul class="mb-0 mt-2">' +
                               data.errors.map(error => `<li>${error}</li>`).join('') +
                               '</ul>';
                } else {
                    for (const [field, errors] of Object.entries(data.errors)) {
                        errorList += `<strong>${field}:</strong> ${errors.join(', ')}<br>`;
                    }
                }
                validationMessage.innerHTML += '<br>' + errorList;
            }

            // 重置按钮状态
            publishButton.disabled = false;
            publishButtonText.style.display = 'inline';
            publishLoading.style.display = 'none';
        }
    })
    .catch(error => {
        console.error('发布失败:', error);
        validationMessage.textContent = '发布失败，请稍后重试';

        // 重置按钮状态
        publishButton.disabled = false;
        publishButtonText.style.display = 'inline';
        publishLoading.style.display = 'none';
    });
});

// 更新页面内容
// 更新页面内容
function updatePageAfterPublish(data) {
    // 更新状态徽章
    const statusBadge = document.querySelector('.card-body .badge');
    if (statusBadge) {
        statusBadge.className = 'badge bg-success';
        statusBadge.textContent = '已发布';
    }

    // 更新版本信息
    const versionBadge = document.querySelector('.update-badge');
    if (versionBadge) {
        versionBadge.textContent = `v${data.version}`;
    }

    // 移除发布按钮
    const publishBtn = document.querySelector('button[data-bs-target="#publishModal"]');
    if (publishBtn) {
        publishBtn.remove();
    }

    // 如果有二维码，更新二维码显示
    if (data.qr_code_url) {
        // 方法1：使用ID选择器（推荐）
        const qrContainer = document.getElementById('qr-code-container');

        // 方法2：如果没有ID，使用更具体的CSS选择器
        // const qrContainer = document.querySelector('.col-md-4 .card .text-center');

        // 方法3：遍历查找包含特定文本的元素
        // let qrContainer = null;
        // const allContainers = document.querySelectorAll('.text-center');
        // for (const container of allContainers) {
        //     const h6 = container.querySelector('h6');
        //     if (h6 && h6.textContent.includes('二维码')) {
        //         qrContainer = container;
        //         break;
        //     }
        // }

        if (qrContainer) {
            qrContainer.innerHTML = `
                <h6>问卷二维码</h6>
                <img src="${data.qr_code_url}" alt="二维码" class="img-fluid mb-2" style="max-width: 150px;">
                <p class="small text-muted">扫描二维码访问问卷</p>
                <div class="copy-link-container">
                    <div class="link-label">问卷链接：</div>
                    <div class="input-group input-group-sm link-input-group">
                        <input type="text" class="form-control"
                               id="questionnaire-link"
                               value="${data.survey_url}"
                               readonly>
                        <button class="btn btn-outline-primary" type="button"
                                onclick="copyQuestionnaireLink()"
                                title="复制链接">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                    <div class="copy-success" id="copy-success" style="display: none;">
                        <i class="fas fa-check-circle me-1"></i>链接已复制到剪贴板
                    </div>
                </div>
            `;
        }
    }

    // 如果有邀请码，更新邀请码显示
    if (data.invite_code) {
        const inviteCodeBtn = document.getElementById('inviteCodeBtn');
        if (inviteCodeBtn) {
            const container = document.getElementById('inviteCodeContainer');
            const input = container.querySelector('#inviteCodeInput');
            input.value = data.invite_code;
            inviteCodeBtn.textContent = '点击显示邀请码';
            container.style.display = 'none';
        }
    }
}
</script>
</body>
</html>